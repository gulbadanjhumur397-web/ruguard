# RugGuard Environment Configuration
# Copy this file to .env and fill in values as needed.

# Server port (Railway sets this automatically)
PORT=3000

# Python command (use "python" if python3 is not available)
PYTHON_CMD=python3

# Timeout for the Python token scanner (ms)
SCANNER_TIMEOUT_MS=30000

# Timeout for the full pipeline (ms)
PIPELINE_TIMEOUT_MS=60000
